# DST Recruitment
APP_ENV=development
APP_DEBUG=true
BASE_URL=http://localhost/dst-recruitment/

# Database
DB_HOST=localhost
DB_NAME=dst_recruitment
DB_USER=root
DB_PASS=

# Upload
MAX_CV_SIZE_MB=5
MAX_AVATAR_SIZE_MB=2

# Mail (Gmail SMTP)
# 1. Aktifkan 2FA di akun Google
# 2. Buat App Password di https://myaccount.google.com/apppasswords
# 3. Isi MAIL_USERNAME dengan email Gmail, MAIL_PASSWORD dengan App Password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=DST Recruitment